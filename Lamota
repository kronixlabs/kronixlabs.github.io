.miedo-q{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;color:rgba(255,255,255,.65);margin-bottom:4px;letter-spacing:.3px;}
.miedo-a{font-size:12px;color:rgba(255,255,255,.38);line-height:1.6;}
.miedo-ico{font-size:20px;flex-shrink:0;margin-top:1px;}
.garantias{display:flex;flex-direction:column;gap:14px;}
.g-item{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:22px 24px;}
