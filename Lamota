<script>
// Fade-up observer
const obs = new IntersectionObserver(e => {
  e.forEach(el => { if(el.isIntersecting) el.target.classList.add('v'); });
},{threshold:0.1});
document.querySelectorAll('.fu').forEach(el => obs.observe(el));

// Contador animado pérdidas
function animCount(el, target, duration=1800){
  let start=null;
  const step = ts => {
    if(!start) start=ts;
    const p = Math.min((ts-start)/duration,1);
    const ease = 1-Math.pow(1-p,3);
    el.textContent = Math.floor(ease*target);
    if(p<1) requestAnimationFrame(step);
  };
  requestAnimationFrame(step);
}
const cnt1 = document.getElementById('cnt1');
const lossObs = new IntersectionObserver(e => {
  e.forEach(el => {
    if(el.isIntersecting && cnt1){
      animCount(cnt1,800);
      lossObs.disconnect();
    }
  });
},{threshold:0.5});
const s02 = document.getElementById('s02');
if(s02) lossObs.observe(s02);

// Nav active link
const secs = document.querySelectorAll('section[id]');
const links = document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{
  let cur='';
  secs.forEach(s=>{ if(window.scrollY>=s.offsetTop-80) cur=s.id; });
  links.forEach(a=>{
    a.classList.remove('act');
    if(a.getAttribute('href')==='#'+cur) a.classList.add('act');
  });
},{passive:true});
</script>
