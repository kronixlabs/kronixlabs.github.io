  border-radius:16px;padding:28px 36px;display:flex;align-items:center;gap:24px;
}
.f2n-ico{font-size:36px;flex-shrink:0;}
.f2n-txt strong{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:20px;color:var(--wh);display:block;margin-bottom:5px;}
.f2n-txt p{font-size:13px;color:rgba(255,255,255,.5);line-height:1.65;}
.f2n-txt em{color:var(--na);font-style:normal;}

