.calc-panel{background:var(--az);border-radius:20px;padding:36px;position:relative;overflow:hidden;}
.calc-panel::after{content:'$';position:absolute;right:-10px;bottom:-20px;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:180px;color:rgba(255,255,255,.025);line-height:1;}
.cp-tag{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:3px;color:var(--do);margin-bottom:18px;}
.cp-h{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:26px;color:var(--wh);margin-bottom:20px;line-height:1.15;}
.calc-rows{display:flex;flex-direction:column;gap:11px;}
.cr{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:rgba(255,255,255,.04);border-radius:8px;border:1px solid rgba(255,255,255,.06);}
.cr-l{font-size:13px;color:rgba(255,255,255,.5);}
.cr-v{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:20px;color:var(--na);}
.cr-total{background:rgba(232,118,43,.08);border-color:rgba(232,118,43,.22);}
.cr-total .cr-l{color:rgba(255,255,255,.75);font-weight:600;}
.cr-total .cr-v{font-size:26px;color:var(--do);}
.calc-nota{margin-top:18px;padding:16px;background:rgba(39,174,96,.07);border-radius:10px;border:1px solid rgba(39,174,96,.18);}
.calc-nota p{font-size:13px;color:rgba(255,255,255,.6);line-height:1.65;}
.calc-nota strong{color:rgba(39,174,96,.9);}

.roi-items{display:flex;flex-direction:column;gap:14px;}
.roi-item{background:var(--wh);border-radius:14px;padding:22px 24px;border:1px solid var(--borde);box-shadow:0 2px 10px rgba(0,0,0,.04);}
.roi-top{display:flex;align-items:center;gap:14px;margin-bottom:10px;}
.roi-ico{width:44px;height:44px;border-radius:10px;background:rgba(26,58,92,.06);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.roi-top strong{font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:800;color:var(--az);letter-spacing:.5px;}
.roi-bar{height:6px;background:var(--gris);border-radius:3px;overflow:hidden;margin-bottom:5px;}
.roi-fill{height:100%;border-radius:3px;background:linear-gradient(to right,var(--na),var(--do));}
.roi-vals{display:flex;justify-content:space-between;font-size:11px;color:var(--sys);}
.roi-vals strong{color:var(--verde);}

/* ══════════════════════════════════
   08 ESCENARIOS
══════════════════════════════════ */
#s08{background:var(--wh);}
.esc-top{text-align:center;margin-bottom:48px;}
.esc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.esc{border-radius:18px;overflow:hidden;border:1px solid var(--borde);transition:all .25s;position:relative;}
.esc:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,.09);}
.esc-rec{border-color:var(--na);box-shadow:0 8px 32px rgba(232,118,43,.18);}
.esc-badge{
  position:absolute;top:-1px;left:50%;transform:translateX(-50%);
  background:var(--na);color:var(--wh);
  font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:10px;letter-spacing:2px;
  padding:4px 14px;border-radius:0 0 8px 8px;
}
.esc-head{padding:28px 26px 22px;}
.e1 .esc-head{background:var(--gris);}
.e2 .esc-head{background:var(--az);}
.e3 .esc-head{background:var(--az2);}
.esc-nivel{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:3px;margin-bottom:5px;}
.e1 .esc-nivel{color:var(--sys);}
.e2 .esc-nivel,.e3 .esc-nivel{color:var(--do);}
.esc-name{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:28px;margin-bottom:4px;}
.e1 .esc-name{color:var(--az);}
.e2 .esc-name,.e3 .esc-name{color:var(--wh);}
.esc-inc{font-size:12px;margin-bottom:18px;}
.e1 .esc-inc{color:var(--sys);}
.e2 .esc-inc,.e3 .esc-inc{color:rgba(255,255,255,.42);}
.esc-inv{padding:8px 14px;border-radius:8px;display:inline-block;margin-bottom:4px;}
.e1 .esc-inv{background:rgba(26,58,92,.07);}
.e2 .esc-inv,.e3 .esc-inv{background:rgba(255,255,255,.07);}
.esc-inv-n{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:38px;line-height:1;}
.e1 .esc-inv-n{color:var(--az);}
.e2 .esc-inv-n,.e3 .esc-inv-n{color:var(--na);}
.esc-inv-l{font-size:10px;font-family:'Barlow Condensed',sans-serif;letter-spacing:1px;}
.e1 .esc-inv-l{color:var(--sys);}
.e2 .esc-inv-l,.e3 .esc-inv-l{color:rgba(255,255,255,.38);}
.esc-body{padding:22px 26px;background:var(--wh);}
.esc-mods{display:flex;flex-direction:column;gap:7px;margin-bottom:16px;}
.em{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text2);}
.em .dot{width:6px;height:6px;border-radius:50%;background:var(--verde);flex-shrink:0;}
.em .dot-no{background:var(--borde);}
.esc-men{padding-top:14px;border-top:1px solid var(--borde);}
.esc-men-n{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:22px;color:var(--az);}
.esc-men-l{font-size:11px;color:var(--sys);}
.esc-roi{margin-top:10px;padding:10px 14px;background:rgba(39,174,96,.05);border-radius:8px;border:1px solid rgba(39,174,96,.14);}
.esc-roi p{font-size:11px;color:var(--verde);font-weight:600;font-family:'Barlow Condensed',sans-serif;letter-spacing:.5px;}

/* ══════════════════════════════════
   09 PLAN 3 MESES
══════════════════════════════════ */
