@keyframes fl{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}

.cta-big{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:62px;color:var(--wh);line-height:.92;margin-bottom:10px;}
.cta-big em{color:var(--na);font-style:normal;}
.cta-line{width:50px;height:2px;background:linear-gradient(to right,var(--na),var(--do));margin:20px auto;border-radius:2px;}
.cta-quote{font-size:17px;font-style:italic;color:rgba(255,255,255,.55);line-height:1.75;margin-bottom:10px;max-width:560px;margin-left:auto;margin-right:auto;}
.cta-firma{font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:4px;color:var(--do);margin-bottom:34px;}
.cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}

.btn-wa{
  background:#25D366;color:var(--wh);border:none;
  font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:14px;letter-spacing:1.5px;
  padding:15px 32px;border-radius:8px;cursor:pointer;text-decoration:none;
