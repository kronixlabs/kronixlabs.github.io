<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kronix Smart-Flow — Arrendamientos La Mota</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;800;900&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════════
   PALETA OFICIAL — INFORMACION_EXTRA.svg
   ══════════════════════════════════════════════
   Primaria:
   #1A3A5C  Azul principal La Mota/Kronix
   #E8762B  Naranja (acento / CTA / logos)
   #C8973F  Dorado (acentos premium)
   UI System:
   #0D1E30  Azul noche (fondos muy oscuros)
   #8BAEC8  Azul gris (textos secundarios, detalles)
   #E8EDF2  Gris claro (fondos secciones light)
   Base:
   #FFFFFF  Blanco
   #060D18  Negro azulado
   ══════════════════════════════════════════════ */
:root{
  --az:     #1A3A5C;
  --az2:    #0D1E30;
  --az3:    #060D18;
  --na:     #E8762B;
  --do:     #C8973F;
  --sys:    #8BAEC8;
  --gris:   #E8EDF2;
  --wh:     #FFFFFF;
  --text:   #060D18;
  --text2:  #4A6070;
  --borde:  #D4DCE5;
  --verde:  #27AE60;
  --rojo:   #E74C3C;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Barlow',sans-serif;background:var(--wh);color:var(--text);overflow-x:hidden;}
h1,h2,h3,h4{font-family:'Barlow Condensed',sans-serif;}

/* ── LOGO M SVG (La Mota vectorial) ── */
/* viewBox original: 61.16 188.72 → ancho ~416, alto ~240 */
.logo-m-svg{display:block;}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:300;
  background:rgba(13,30,48,0.97);
  backdrop-filter:blur(14px);
  height:58px;display:flex;align-items:center;
  justify-content:space-between;padding:0 48px;
  border-bottom:1px solid rgba(200,151,63,.18);
}
.nav-l{display:flex;align-items:center;gap:12px;}
/* Logo nav: ícono M naranja + texto */
.nav-m-wrap{
  width:38px;height:38px;border-radius:8px;
  background:var(--na);
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;flex-shrink:0;
}
.nav-m-wrap svg{width:28px;height:18px;}
.nav-brand{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:900;font-size:17px;color:var(--wh);
  letter-spacing:.5px;line-height:1.1;
}
.nav-brand span{display:block;}
.nav-brand .sub{font-weight:400;font-size:10px;letter-spacing:3px;color:var(--sys);}
.nav-divider{width:1px;height:26px;background:rgba(255,255,255,.1);margin:0 8px;}
.nav-powered{font-size:9px;letter-spacing:2px;color:rgba(200,151,63,.6);font-family:'Barlow Condensed',sans-serif;font-weight:700;}
.nav-links{display:flex;gap:2px;}
.nav-links a{
  font-family:'Barlow Condensed',sans-serif;font-weight:600;
  font-size:10px;letter-spacing:1.5px;color:rgba(255,255,255,.45);
  text-decoration:none;padding:5px 10px;border-radius:4px;transition:all .2s;
}
.nav-links a:hover,.nav-links a.act{color:var(--wh);background:rgba(255,255,255,.07);}

/* ── LAYOUT ── */
section{position:relative;overflow:hidden;}
.si{max-width:1180px;margin:0 auto;padding:90px 60px;}

/* ── CHIPS ── */
.chip{
  display:inline-flex;align-items:center;gap:6px;
  font-family:'Barlow Condensed',sans-serif;font-weight:700;
  font-size:10px;letter-spacing:3px;text-transform:uppercase;
  padding:4px 14px;border-radius:100px;margin-bottom:18px;
}
.ch-na{background:rgba(232,118,43,.1);color:var(--na);border:1px solid rgba(232,118,43,.25);}
.ch-az{background:rgba(26,58,92,.08);color:var(--az);border:1px solid rgba(26,58,92,.15);}
.ch-do{background:rgba(200,151,63,.1);color:var(--do);border:1px solid rgba(200,151,63,.25);}
.ch-wh{background:rgba(255,255,255,.1);color:var(--wh);border:1px solid rgba(255,255,255,.18);}
.ch-sys{background:rgba(139,174,200,.12);color:var(--sys);border:1px solid rgba(139,174,200,.25);}
.ch-vd{background:rgba(39,174,96,.1);color:var(--verde);border:1px solid rgba(39,174,96,.25);}

/* ── TÍTULOS ── */
.h2{font-size:56px;font-weight:900;line-height:.92;color:var(--az);margin-bottom:14px;}
.h2 em{font-style:normal;color:var(--na);}
.h2w{color:var(--wh);}
.h2w em{color:var(--na);}
.bajada{font-size:15px;color:var(--text2);line-height:1.78;max-width:520px;}
.bajadaw{color:rgba(255,255,255,.55);}

/* ── FADE UP ── */
.fu{opacity:0;transform:translateY(22px);transition:opacity .6s ease,transform .6s ease;}
.fu.v{opacity:1;transform:translateY(0);}
.d1{transition-delay:.1s;}.d2{transition-delay:.2s;}.d3{transition-delay:.3s;}.d4{transition-delay:.4s;}

/* ── DIVIDER ── */
.dvd{height:1px;background:linear-gradient(to right,transparent,rgba(200,151,63,.2) 30%,rgba(200,151,63,.2) 70%,transparent);}

/* ══════════════════════════════════
   01 HERO
══════════════════════════════════ */
#s01{background:var(--az2);min-height:100vh;display:flex;align-items:center;}
#s01::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 55% 70% at 100% 50%,rgba(232,118,43,.06),transparent 60%),
    radial-gradient(ellipse 35% 50% at 0% 100%,rgba(6,13,24,.6),transparent);
}
#s01::after{
  content:'';position:absolute;right:0;top:0;bottom:0;width:38%;
  background:rgba(255,255,255,.012);
  clip-path:polygon(15% 0,100% 0,100% 100%,0 100%);
}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;position:relative;z-index:1;}

/* HERO — izquierda */
.hero-tag{
  font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:11px;
  letter-spacing:5px;color:var(--do);text-transform:uppercase;margin-bottom:20px;
  display:flex;align-items:center;gap:10px;
}
.hero-tag::before{content:'';width:28px;height:1px;background:var(--do);}
.hero-h1{font-size:80px;font-weight:900;line-height:.88;color:var(--wh);margin-bottom:22px;letter-spacing:-1px;}
.hero-h1 .na{color:var(--na);}
.hero-p{font-size:16px;color:rgba(255,255,255,.58);line-height:1.78;max-width:400px;margin-bottom:32px;}
.btns{display:flex;gap:12px;flex-wrap:wrap;}

.btn-p{
  background:var(--na);color:var(--wh);border:none;
  font-family:'Barlow Condensed',sans-serif;font-weight:800;
  font-size:13px;letter-spacing:2px;padding:14px 28px;border-radius:7px;
  cursor:pointer;text-decoration:none;transition:all .2s;
  display:inline-flex;align-items:center;gap:8px;
}
.btn-p:hover{background:#d46a22;transform:translateY(-2px);box-shadow:0 10px 28px rgba(232,118,43,.35);}
.btn-s{
  background:transparent;color:rgba(255,255,255,.7);
  border:1px solid rgba(255,255,255,.18);
  font-family:'Barlow Condensed',sans-serif;font-weight:700;
  font-size:13px;letter-spacing:2px;padding:14px 28px;border-radius:7px;
  cursor:pointer;text-decoration:none;transition:all .2s;
  display:inline-flex;align-items:center;gap:8px;
}
.btn-s:hover{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.32);}

/* HERO — tarjeta derecha */
.hero-card{
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);
  backdrop-filter:blur(20px);border-radius:20px;padding:34px;position:relative;
}
.hero-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(to right,var(--na),var(--do));
  border-radius:20px 20px 0 0;
}
.hc-tag{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:3px;color:var(--do);margin-bottom:22px;}
.kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.kpi{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:18px 16px;text-align:center;}
.kpi-n{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:44px;line-height:1;color:var(--na);margin-bottom:4px;}
.kpi-n sup{font-size:20px;}
.kpi-l{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:10px;letter-spacing:1.5px;color:rgba(255,255,255,.38);line-height:1.5;}
.kpi-full{grid-column:1/-1;background:rgba(232,118,43,.05);border-color:rgba(232,118,43,.15);}
.kpi-full .kpi-n{font-size:34px;}

/* ══════════════════════════════════
   02 LO QUE ESTÁ PERDIENDO
══════════════════════════════════ */
#s02{background:var(--gris);}
.perdida-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
.dolor-items{display:flex;flex-direction:column;gap:13px;margin-top:26px;}
.dolor-item{
  background:var(--wh);border-radius:12px;padding:18px 20px;
  border-left:3px solid transparent;
  box-shadow:0 2px 12px rgba(0,0,0,.05);
  display:flex;gap:14px;transition:all .25s;
}
.dolor-item:hover{border-left-color:var(--rojo);transform:translateX(4px);}
.di-ico{font-size:22px;flex-shrink:0;margin-top:2px;}
.di-txt strong{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;letter-spacing:.5px;color:var(--az);display:block;margin-bottom:3px;}
.di-txt span{font-size:13px;color:var(--text2);line-height:1.65;}

/* Panel naranja derecho */
.cifra-panel{background:var(--az);border-radius:20px;padding:36px;position:relative;overflow:hidden;}
.cifra-panel::before{content:'';position:absolute;top:-40px;right:-40px;width:180px;height:180px;background:rgba(232,118,43,.05);border-radius:50%;}
.cf-top{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:3px;color:var(--do);margin-bottom:18px;}
.cf-big{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:96px;color:var(--na);line-height:1;}
.cf-big sup{font-size:44px;}
.cf-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;color:var(--wh);letter-spacing:1px;margin:4px 0 6px;}
.cf-desc{font-size:13px;color:rgba(255,255,255,.45);line-height:1.65;margin-bottom:22px;}
.cf-row{display:flex;flex-direction:column;gap:10px;}
.cf-item{
  display:flex;align-items:center;gap:12px;
  padding:11px 14px;background:rgba(255,255,255,.04);
  border-radius:9px;border:1px solid rgba(255,255,255,.06);
}
.cf-item .n{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:22px;color:var(--na);min-width:64px;}
.cf-item .t{font-size:12px;color:rgba(255,255,255,.5);line-height:1.5;}

/* ══════════════════════════════════
   03 USTED VS COMPETENCIA
══════════════════════════════════ */
#s03{background:var(--wh);}
.comp-table-wrap{margin-top:40px;border-radius:16px;overflow:hidden;border:1px solid var(--borde);box-shadow:0 8px 32px rgba(0,0,0,.06);}
table{width:100%;border-collapse:collapse;}
thead tr{background:var(--az2);}
th{padding:16px 20px;text-align:left;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;letter-spacing:2.5px;color:rgba(255,255,255,.55);}
th.col-kr{color:var(--na) !important;}
tbody tr{border-bottom:1px solid var(--borde);transition:background .15s;}
tbody tr:hover{background:rgba(26,58,92,.025);}
tbody tr:last-child{border-bottom:none;}
td{padding:15px 20px;font-size:14px;color:var(--text2);}
td:first-child{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:14px;letter-spacing:.5px;color:var(--az);}
.si-ico{color:var(--verde);font-size:18px;font-weight:900;}
.no-ico{color:var(--rojo);font-size:18px;}
.winner-row td{background:rgba(39,174,96,.04) !important;}
.winner-row td:first-child{color:var(--verde) !important;}
.comp-nota{margin-top:20px;padding:18px 24px;background:rgba(26,58,92,.04);border-radius:10px;border-left:3px solid var(--do);}
.comp-nota p{font-size:14px;color:var(--text2);line-height:1.72;}
.comp-nota strong{color:var(--az);}

/* ══════════════════════════════════
   04 CÓMO FUNCIONA
══════════════════════════════════ */
#s04{background:var(--gris);}
.pasos-top{text-align:center;margin-bottom:48px;}
.pasos-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;position:relative;}
.pasos-grid::before{
  content:'';position:absolute;top:38px;left:12%;right:12%;height:2px;
  background:linear-gradient(to right,var(--na),var(--do));z-index:0;
}
.paso{
  background:var(--wh);border-radius:16px;padding:28px 22px;
  border:1px solid var(--borde);text-align:center;position:relative;z-index:1;
  transition:all .25s;box-shadow:0 2px 12px rgba(0,0,0,.04);
}
.paso:hover{box-shadow:0 12px 36px rgba(26,58,92,.1);transform:translateY(-4px);}
.paso-n{
  width:52px;height:52px;border-radius:50%;background:var(--na);
  display:flex;align-items:center;justify-content:center;
  font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:22px;color:var(--wh);
  margin:0 auto 14px;
}
.paso h3{font-size:16px;font-weight:800;color:var(--az);margin-bottom:6px;letter-spacing:.5px;}
.paso-estado{
  font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:700;
  letter-spacing:2px;padding:3px 8px;border-radius:4px;display:inline-block;margin-bottom:10px;
}
.pe-na{background:rgba(232,118,43,.1);color:var(--na);}
.pe-sys{background:rgba(139,174,200,.12);color:var(--sys);}
.pe-az{background:rgba(26,58,92,.1);color:var(--az);}
.pe-vd{background:rgba(39,174,96,.1);color:var(--verde);}
.paso p{font-size:12px;color:var(--text2);line-height:1.65;}
.paso .ej{margin-top:12px;padding:10px;background:var(--gris);border-radius:7px;font-size:11px;color:rgba(0,0,0,.4);font-style:italic;line-height:1.5;}

/* ══════════════════════════════════
   05 LO QUE VE EL CLIENTE
══════════════════════════════════ */
#s05{background:var(--az2);}
#s05::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 100% 0%,rgba(232,118,43,.05),transparent 60%);}
.cliente-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;position:relative;z-index:1;}
.feat-items{display:flex;flex-direction:column;gap:13px;}
.feat{
  display:flex;gap:16px;padding:18px 20px;
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);
  border-radius:12px;transition:all .2s;
}
.feat:hover{background:rgba(255,255,255,.07);}
.feat-ico{
  width:44px;height:44px;border-radius:10px;
  background:rgba(232,118,43,.12);
  display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;
}
.feat-txt strong{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;letter-spacing:.5px;color:var(--wh);display:block;margin-bottom:3px;}
.feat-txt span{font-size:12px;color:rgba(255,255,255,.42);line-height:1.6;}

/* Web mock */
.web-mock{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:16px;overflow:hidden;}
.wm-bar{background:rgba(0,0,0,.25);padding:8px 14px;display:flex;gap:5px;align-items:center;}
.wm-dot{width:8px;height:8px;border-radius:50%;}
.wm-url{flex:1;background:rgba(255,255,255,.06);border-radius:4px;padding:4px 10px;font-size:9px;color:rgba(255,255,255,.28);font-family:'Barlow Condensed',sans-serif;letter-spacing:1px;margin-left:8px;}
.wm-nav{background:var(--az);padding:10px 18px;display:flex;align-items:center;justify-content:space-between;}
.wm-logo{display:flex;align-items:center;gap:7px;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:15px;color:var(--wh);}
/* Logo M en web-mock: mini SVG */
.wm-logo-m{width:22px;height:14px;overflow:visible;}
.wm-logo span{color:var(--na);}
.wm-menu{display:flex;gap:14px;font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:1px;color:rgba(255,255,255,.38);}
.wm-body{padding:18px;}
.wm-search{background:rgba(255,255,255,.05);border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:8px;margin-bottom:14px;}
.wm-search span{font-size:10px;color:rgba(255,255,255,.28);font-family:'Barlow Condensed',sans-serif;}
.wm-cards{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.wm-card{background:rgba(255,255,255,.05);border-radius:8px;overflow:hidden;}
.wm-img{height:52px;display:flex;align-items:center;justify-content:center;font-size:18px;}
.wm-card-info{padding:8px;}
.wm-card-info .cod{font-family:'Barlow Condensed',sans-serif;font-size:8px;letter-spacing:1.5px;color:var(--na);font-weight:700;}
.wm-card-info .prec{font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:900;color:var(--wh);}
.wm-card-info .loc{font-size:9px;color:rgba(255,255,255,.28);}
.wm-wa{margin-top:12px;background:rgba(37,211,102,.08);border:1px solid rgba(37,211,102,.18);border-radius:8px;padding:10px 14px;display:flex;gap:10px;align-items:center;}
.wm-wa .wa-txt{font-size:10px;color:rgba(255,255,255,.45);line-height:1.5;}
.wm-wa .wa-cod{color:rgba(37,211,102,.8);font-weight:600;}

/* ══════════════════════════════════
   06 MÓDULOS
══════════════════════════════════ */
#s06{background:var(--wh);}
.mods-top{text-align:center;margin-bottom:48px;}
.mods-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:28px;}
.mod{border-radius:18px;overflow:hidden;border:1px solid var(--borde);transition:all .25s;box-shadow:0 4px 16px rgba(0,0,0,.05);}
.mod:hover{box-shadow:0 16px 48px rgba(0,0,0,.11);transform:translateY(-4px);}
.mod-head{padding:24px 26px 20px;position:relative;}
.m1 .mod-head{background:var(--az);}
.m2 .mod-head{background:var(--az2);}
.m3 .mod-head{background:var(--az3);}
.mod-num{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:64px;color:rgba(255,255,255,.06);position:absolute;right:16px;top:8px;line-height:1;}
.mod-tag{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:9px;letter-spacing:3px;color:rgba(255,255,255,.38);margin-bottom:5px;}
.mod-name{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:24px;color:var(--wh);line-height:1.1;margin-bottom:7px;}
.mod-desc{font-size:12px;color:rgba(255,255,255,.5);line-height:1.65;}
.mod-body{padding:20px 26px;background:var(--wh);}
.mod-feats{display:flex;flex-direction:column;gap:8px;margin-bottom:18px;}
.mf{display:flex;gap:8px;align-items:flex-start;font-size:12px;color:var(--text2);line-height:1.55;}
.mf::before{content:'✓';color:var(--verde);font-weight:900;flex-shrink:0;margin-top:1px;}
.mod-precio{border-top:1px solid var(--borde);padding-top:16px;}
.mp-unico{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--sys);margin-bottom:3px;}
.mp-val{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:32px;color:var(--az);line-height:1;}
.mp-val span{font-size:14px;font-weight:600;color:var(--sys);}
.mp-men{font-size:12px;color:var(--sys);margin-top:4px;}
.mp-men strong{color:var(--na);}

.gestion-card{
  background:linear-gradient(135deg,var(--az),var(--az2));
  border-radius:16px;padding:28px 32px;
  display:flex;align-items:center;justify-content:space-between;gap:30px;
}
.gc-left h3{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:24px;color:var(--wh);margin-bottom:6px;}
.gc-left p{font-size:13px;color:rgba(255,255,255,.5);line-height:1.65;max-width:500px;}
.gc-right{text-align:center;flex-shrink:0;}
.gc-n{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:56px;color:var(--na);line-height:1;}
.gc-l{font-size:11px;letter-spacing:2px;color:rgba(255,255,255,.38);font-family:'Barlow Condensed',sans-serif;font-weight:600;}

/* ══════════════════════════════════
   07 EL CÁLCULO
══════════════════════════════════ */
