.g-item strong{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:16px;color:var(--wh);letter-spacing:.5px;display:block;margin-bottom:4px;}
.g-item p{font-size:12px;color:rgba(255,255,255,.42);line-height:1.65;}

/* ══════════════════════════════════
   11 FASE 2
══════════════════════════════════ */
#s11{background:var(--gris);}
.fase2-header{text-align:center;margin-bottom:48px;}
.fase2-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(200,151,63,.1);border:1px solid rgba(200,151,63,.28);
  border-radius:100px;padding:6px 16px;
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;letter-spacing:3px;color:var(--do);margin-bottom:18px;
}
.agentes-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.agente{
  background:var(--wh);border-radius:14px;padding:22px 18px;
  border:1px solid var(--borde);box-shadow:0 2px 10px rgba(0,0,0,.04);
  transition:all .25s;position:relative;overflow:hidden;
}
.agente:hover{box-shadow:0 10px 32px rgba(26,58,92,.09);transform:translateY(-3px);}
.agente::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(to right,var(--na),var(--do));
  transform:scaleX(0);transition:transform .3s;transform-origin:left;
}
.agente:hover::before{transform:scaleX(1);}
.ag-ico{font-size:28px;margin-bottom:12px;}
.ag-name{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:15px;color:var(--az);letter-spacing:.5px;margin-bottom:5px;}
.ag-desc{font-size:12px;color:var(--text2);line-height:1.6;}
.ag-tag{margin-top:11px;font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:700;letter-spacing:2px;color:var(--na);}
.fase2-nota{
